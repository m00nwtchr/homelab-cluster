{
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "models": {
        "agentgateway/MiniMax-M3": {
          "alias": "MiniMax"
        }
      },
      "model": {
        "primary": "MiniMax"
      },
      "imageGenerationModel": {
        "primary": "minimax/image-01"
      },
      "memorySearch": {
        "provider": "local",
        "enabled": true,
        "local": {
          "modelPath": "hf:ggml-org/embeddinggemma-300M-GGUF/embeddinggemma-300M-Q8_0.gguf"
        },
        "sync": {
          "watch": true
        },
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3
          }
        }
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "24h",
        "keepLastAssistants": 4,
        "softTrimRatio": 0.3,
        "hardClearRatio": 0.5,
        "minPrunableToolChars": 6000,
        "softTrim": {
          "maxChars": 4000,
          "headChars": 1500,
          "tailChars": 1500
        },
        "hardClear": {
          "enabled": true,
          "placeholder": "[Old tool result content cleared]"
        }
      },
      "compaction": {
        "mode": "default",
        "reserveTokensFloor": 24000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 12000,
          "prompt": "Extract key decisions, state changes, lessons, blockers to memory/YYYY-MM-DD.md. Format: ## [HH:MM] Topic. Skip routine work. NO_FLUSH if nothing important.",
          "systemPrompt": "Compacting session context. Extract only what's worth remembering. No fluff."
        }
      },
      "thinkingDefault": "low"
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "custom",
    "customBindHost": "::",
    "trustedProxies": ["10.0.0.1", "172.17.0.1"],
    "auth": {
      "mode": "token",
      "token": "$${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowInsecureAuth": true,
      "allowedOrigins": ["https://openclaw.${SECRET_DOMAIN}"]
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send",
        "sms.search"
      ]
    }
  },
  "session": {
    "dmScope": "main",
    "reset": {
      "mode": "idle",
      "idleMinutes": 1440
    },
    "maintenance": {
      "mode": "enforce",
      "pruneAfter": "7d",
      "maxEntries": 1000,
      "resetArchiveRetention": "7d"
    }
  },
  "tools": {
    "profile": "full",
    "web": {
      "search": {
        "provider": "brave",
        "enabled": true,
        "openaiCodex": {}
      },
      "fetch": {
        "enabled": true
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "agentgateway": {
        "baseUrl": "http://agentgateway-proxy.ai.svc.cluster.local./anthropic",
        "api": "anthropic-messages",
        "apiKey": "dummy",
        "models": [
          {
            "id": "MiniMax-M3",
            "name": "MiniMax M3",
            "reasoning": true,
            "input": ["text", "image"],
            "cost": {
              "input": 0.6,
              "output": 2.4,
              "cacheRead": 0.12,
              "cacheWrite": 0
            },
            "contextWindow": 1000000,
            "maxTokens": 131072
          },
          {
            "id": "MiniMax-M2.7",
            "name": "MiniMax M2.7",
            "reasoning": true,
            "input": ["text", "image"],
            "cost": {
              "input": 0.3,
              "output": 1.2,
              "cacheRead": 0.06,
              "cacheWrite": 0.375
            },
            "contextWindow": 204800,
            "maxTokens": 131072
          }
        ]
      },
      "minimax": {
        "baseUrl": "https://api.minimax.io/anthropic",
        "models": [],
        "api": "anthropic-messages",
        "authHeader": true
      }
    }
  },
  "auth": {
    "profiles": {
      "minimax:global": {
        "provider": "minimax",
        "mode": "api_key"
      }
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": {
          "enabled": true
        },
        "bootstrap-extra-files": {
          "enabled": true
        },
        "session-memory": {
          "enabled": false
        },
        "command-logger": {
          "enabled": false
        },
        "moon-phase": {
          "enabled": true
        }
      }
    }
  },
  "wizard": {
    "lastRunAt": "2026-06-21T19:52:46.069Z",
    "lastRunVersion": "2026.6.6",
    "lastRunCommand": "doctor",
    "lastRunMode": "local"
  },
  "meta": {
    "lastTouchedVersion": "2026.6.6",
    "lastTouchedAt": "2026-06-21T19:52:46.237Z"
  },
  "memory": {
    "backend": "qmd",
    "qmd": {
      "sessions": {
        "enabled": true
      }
    }
  },
  "plugins": {
    "allow": [
      "brave",
      "matrix",
      "minimax",
      "lossless-claw",
      "browser",
      "memory-wiki",
      "memory-core",
      "openclaw-honcho"
    ],
    "entries": {
      "brave": {
        "enabled": true,
        "config": {
          "webSearch": {
            "apiKey": "$${BRAVE_SEARCH_API_KEY}"
          }
        }
      },
      "minimax": {
        "enabled": true
      },
      "memory-core": {
        "enabled": true,
        "config": {
          "dreaming": {
            "enabled": true
          }
        }
      },
      "memory-lancedb-pro": {
        "enabled": false,
        "config": {
          "embedding": {
            "apiKey": "ollama",
            "model": "mxbai-embed-large",
            "baseURL": "http://ollama.ai.svc.cluster.local/v1",
            "dimensions": 1024,
            "taskQuery": "retrieval.query",
            "taskPassage": "retrieval.passage",
            "normalized": true
          },
          "llm": {
            "model": "MiniMax-M2.7",
            "baseURL": "https://api.minimax.io/v1",
            "apiKey": "$${MINIMAX_API_KEY}",
            "timeoutMs": 120000
          },
          "enableManagementTools": false,
          "sessionStrategy": "memoryReflection",
          "autoCapture": true,
          "autoRecall": true,
          "autoRecallMinLength": 15,
          "autoRecallMinRepeated": 8,
          "autoRecallMaxItems": 3,
          "autoRecallMaxChars": 600,
          "autoRecallPerItemMaxChars": 180,
          "smartExtraction": true,
          "extractMinMessages": 2,
          "extractMaxChars": 8000,
          "retrieval": {
            "mode": "hybrid",
            "vectorWeight": 0.7,
            "bm25Weight": 0.3,
            "filterNoise": true,
            "minScore": 0.25,
            "hardMinScore": 0.28
          },
          "scopes": {
            "definitions": {
              "global": {
                "description": "Shared memories across all agents"
              },
              "ash": {
                "description": "Ash's private memories"
              },
              "rag:ash": {
                "description": "Ash RAG corpus - chat, preferences"
              },
              "rag:shared": {
                "description": "Shared team docs and conventions"
              }
            },
            "agentAccess": {
              "main": ["global", "ash", "rag:ash", "rag:shared"]
            }
          }
        }
      },
      "memory-wiki": {
        "enabled": true,
        "config": {
          "vaultMode": "bridge",
          "vault": {
            "path": "/home/node/.openclaw/wiki/main",
            "renderMode": "native"
          },
          "bridge": {
            "enabled": true,
            "readMemoryArtifacts": true,
            "indexDreamReports": true,
            "indexDailyNotes": true,
            "indexMemoryRoot": true,
            "followMemoryEvents": true
          },
          "search": {
            "backend": "shared",
            "corpus": "all"
          },
          "render": {
            "preserveHumanBlocks": true,
            "createBacklinks": true,
            "createDashboards": true
          }
        }
      },
      "browser": {
        "enabled": true
      },
      "lossless-claw": {
        "enabled": true,
        "config": {
          "freshTailCount": 64,
          "leafChunkTokens": 80000,
          "newSessionRetainDepth": 2,
          "contextThreshold": 0.75,
          "incrementalMaxDepth": 1,
          "cacheAwareCompaction": {
            "enabled": true,
            "cacheTTLSeconds": 300
          },
          "ignoreSessionPatterns": ["agent:*:cron:**"],
          "transcriptGcEnabled": false,
          "proactiveThresholdCompactionMode": "deferred",
          "delegationTimeoutMs": 300000,
          "summaryTimeoutMs": 60000
        }
      },
      "memini": {
        "enabled": true,
        "hooks": {
          "allowConversationAccess": true
        },
        "config": {
          "base_url": "http://memini.ai.svc.cluster.local",
          "namespace": "openclaw",
          "namespace_per_agent": true,
          "skip_without_agent": true,
          "fallback_on_error": true,
          "timeout_ms": 5000,
          "skip_system_turns": true,
          "expose_tools": true
        }
      },
      "openclaw-honcho": {
        "config": {
          "baseUrl": "http://honcho.ai.svc.cluster.local",
          "workspaceId": "openclaw"
        }
      }
    },
    "slots": {
      "memory": "openclaw-honcho",
      "contextEngine": "lossless-claw"
    }
  },
  "channels": {
    "matrix": {
      "enabled": true,
      "homeserver": "https://matrix.${SECRET_DOMAIN}",
      "userId": "@ash:${SECRET_DOMAIN}",
      "password": "$${ASH_MATRIX_PASSWORD}",
      "deviceName": "OpenClaw Gateway",
